# Copy this file to `env.txt` and fill in the keys for the providers you want to
# use. `env.txt` is git-ignored — never commit real keys. A provider's tab only
# works when its key is present; you don't need all of them.

# Server logging: INFO (default) or DEBUG (logs query params, upstream URLs, response bodies)
LOG_LEVEL=INFO

# ── Provider API keys (one per provider tab) ──
EXA_API_KEY=your-exa-api-key
YDC_API_KEY=your-you.com-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
PARALLEL_API_KEY=your-parallel-api-key
TAVILY_API_KEY=your-tavily-api-key
BRAVE_API_KEY=your-brave-subscription-token
SERPAPI_API_KEY=your-serpapi-api-key

# CORS — set this when deploying beyond localhost
# ALLOWED_ORIGIN=https://your-domain.com
